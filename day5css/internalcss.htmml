<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
       /* TagName{
            Css Prop
       } */

       button{
           background-color: blue;
           color: white;
           font-style: italic;
       }

       h2{
        color: brown;
       }

       div h2{
        color: blue;
       }

       div{
        text-align: center;
        background-color: beige;
        width: 200px;
        height: 200px;
       }

    </style>
</head>
<body>
    <button>Log in</button>

    <h2>Menu</h2>

    <div>
        <h2>Coffee</h2>
        <p>Rs 200</p>
    </div>

     <div>
        <h2>Cake</h2>
        <p>Rs 100</p>
    </div>

</body>
</html>